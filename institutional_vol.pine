// This Pine Script indicator places dots below candles when volume exceeds average volume
// @version=5
indicator("Volume Above Average Dots", overlay=true)

// Input for the length of the volume average
lengthInput = input.int(20, title="Volume MA Length", minval=1)
dotSize = input.int(5, title="Dot Size", minval=1, maxval=10)
dotColor = input.color(color.green, title="Dot Color")

// Calculate the average volume
volumeMA = ta.sma(volume, lengthInput)

// Determine if current volume is greater than average
isVolumeAboveAverage = volume > volumeMA

// Plot dots below candles when volume is above average
plotshape(isVolumeAboveAverage ? true : na, title="Volume > Average", location=location.belowbar, color=dotColor, style=shape.circle, size=size.tiny)

// Optional: Add an alert condition
alertcondition(isVolumeAboveAverage, title="Volume Above Average", message="Volume is above the {{lengthInput}}-period average")