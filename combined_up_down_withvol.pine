//@version=5
indicator("3 EMA with RVOL, Significant Move and ADR% Detector", overlay=true)

// =========== User Inputs ===========
// EMA Settings
emaLength1 = input(9, title="EMA 1 Length")
emaLength2 = input(21, title="EMA 2 Length")
emaLength3 = input(50, title="EMA 3 Length")

// RVOL Settings
rvolLength = input(20, title="RVOL Length")

// Significant Move Settings
pctChangeThreshold = input.float(5.0, "Significant Move % Threshold", minval=0.1, step=0.1)
volumeThreshold = input.int(500000, "Volume Threshold", minval=1000)

// ADR Settings
adrLength = input(20, title="ADR Period")
adrThreshold = input.float(3.0, title="ADR Threshold %", minval=0.1, step=0.1)

// =========== Calculations ===========
// EMA Calculations
ema1 = ta.ema(close, emaLength1)
ema2 = ta.ema(close, emaLength2)
ema3 = ta.ema(close, emaLength3)

// RVOL Calculation
avgVolume = ta.sma(volume, rvolLength)
rvol = (volume / avgVolume) * 100

// ADR Calculation
dailyRange = high / low
avgDailyRange = ta.sma(dailyRange, adrLength)
adrPercent = (avgDailyRange - 1) * 100

// =========== Plotting ===========
// Plot EMAs
plot(ema1, title="EMA 1", color=color.blue, linewidth=2)
plot(ema2, title="EMA 2", color=color.orange, linewidth=2)
plot(ema3, title="EMA 3", color=color.green, linewidth=2)

// Background color when ADR exceeds threshold
bgcolor(adrPercent >= adrThreshold ? color.new(color.yellow, 90) : na, title="ADR Above Threshold")

// =========== Information Table ===========
// Create table and display in the top right corner
table infoTable = table.new(position.top_right, columns=2, rows=7, border_width=1)

// Fill table with values on the last bar
if barstate.islast
    // EMA values
    table.cell(infoTable, 0, 1, "EMA " + str.tostring(emaLength1), text_color=color.blue)
    table.cell(infoTable, 1, 1, str.tostring(ema1, '#.##'), text_color=color.blue)
    
    table.cell(infoTable, 0, 2, "EMA " + str.tostring(emaLength2), text_color=color.orange)
    table.cell(infoTable, 1, 2, str.tostring(ema2, '#.##'), text_color=color.orange)
    
    table.cell(infoTable, 0, 3, "EMA " + str.tostring(emaLength3), text_color=color.green)
    table.cell(infoTable, 1, 3, str.tostring(ema3, '#.##'), text_color=color.green)
    
    // RVOL value
    table.cell(infoTable, 0, 4, "RVOL", text_color=color.purple)
    table.cell(infoTable, 1, 4, str.tostring(rvol, '#.##') + "%", text_color=color.purple)
    
    // ADR value
    adrColor = adrPercent >= adrThreshold ? color.lime : color.gray
    table.cell(infoTable, 0, 5, "ADR", text_color=adrColor)
    table.cell(infoTable, 1, 5, str.tostring(adrPercent, '#.##') + "%", text_color=adrColor)


